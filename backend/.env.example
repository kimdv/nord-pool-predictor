# PostgreSQL
DATABASE_URL=postgresql+asyncpg://nordpool:nordpool@localhost:5432/nordpool

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Model storage path
MODEL_DIR=/data/models

# Data retention (days)
RETENTION_WEATHER_OBS_DAYS=180
RETENTION_WEATHER_FC_DAYS=365
RETENTION_PRODUCTION_DAYS=365
RETENTION_CROSSBORDER_DAYS=365
RETENTION_FORECAST_DAYS=365

# Training window (days)
TRAINING_WINDOW_DAYS=365
